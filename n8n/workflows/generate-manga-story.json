    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output[0].content[0].text;\n\nlet cleaned = raw.trim();\nif (cleaned.startsWith('```')) {\n  cleaned = cleaned.replace(/```json/g, '').replace(/```/g, '').trim();\n}\n\nconst parsed = JSON.parse(cleaned);\nconst pages = parsed.pages || [parsed.page];\nconst universe = parsed.universe || null;\n\nconst BUCKET = 'BD-Pages';\nconst SUPABASE_URL = 'https://wddatxgqhdiosuhcztex.supabase.co';\nconst now = new Date().toISOString();\n\nconst CHARACTER_LOCK = `\\nMain character reference (STRICT - MUST remain identical in every image):\\n\\n8-year-old girl\\nshort straight black bob haircut\\nsmall red ribbon on the LEFT side of her head\\nlarge emerald green eyes\\nsoft round child face\\nblue adventure tunic with golden trim\\nbrown leather boots\\nsmall side satchel\\nglowing star-shaped pendant around her neck\\n\\nDO NOT change character design.\\nDO NOT change outfit.\\nDO NOT move ribbon.\\n`;\n\nreturn pages.map(page => {\n  const universeId = page.universe_id;\n  const pageNumber = page.page_number;\n  const fileName = `${universeId}-page-${pageNumber}.png`;\n  const storagePath = `${universeId}/${fileName}`;\n\n  return {\n    json: {\n      universe,\n      universeId,\n      pageNumber,\n      paragraphText: page.paragraph_text,\n      sceneSummary: page.scene_summary,\n      panels: page.panels,\n      choices: page.choices || [],\n      storyStarts: parsed.story_starts || [],\n      bucket: BUCKET,\n      fileName,\n      storagePath,\n      supabaseUrl: SUPABASE_URL,\n      createdAt: now,\n      geminiPrompt: `Create a full children manga page illustration.\\n\\nSTYLE:\\nSoft pastel Japanese children manga style.\\nNo text. No speech bubbles. No typography.\\n\\n${CHARACTER_LOCK}\\n\\nSCENE:\\n${page.scene_summary}\\n\\nPANELS:\\n${JSON.stringify(page.panels, null, 2)}\\n\\nMaintain strict character consistency.`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 0],
      "id": "c7a16c70-ee98-46e3-9eb7-33061d5cd04d",
      "name": "Parse story JSON"
    },

    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst u = item.universe;\nif (!u) return [];\nreturn [{\n  json: {\n    id: u.id,\n    name: u.name,\n    description: u.description,\n    image_url: u.image_url || '',\n    color: u.color,\n    emoji: u.emoji,\n    gender: u.gender,\n    display_order: u.display_order\n  }\n}];"
      },
