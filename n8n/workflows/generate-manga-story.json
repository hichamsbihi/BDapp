        "jsCode": "const parseItem = $('Parse story JSON').first().json;\nconst starts = parseItem.storyStarts || [];\nconst universeId = parseItem.universeId;\n\nif (!starts.length) return [];\n\nreturn starts.map(s => ({\n  json: {\n    id: s.id,\n    universe_id: universeId,\n    title: s.title,\n    text: s.text\n  }\n}));"
      },
