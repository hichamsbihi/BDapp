        "jsCode": "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const choices = item.json.choices || [];\n  choices.forEach((choice, index) => {\n    results.push({\n      json: {\n        id: choice.id,\n        universe_id: item.json.universeId,\n        page_number: item.json.pageNumber,\n        choice_order: index + 1,\n        text: choice.text,\n        created_at: item.json.createdAt\n      }\n    });\n  });\n}\nreturn results;"
